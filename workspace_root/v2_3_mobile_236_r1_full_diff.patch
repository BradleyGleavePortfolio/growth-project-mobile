+              style={[
+                styles.modalButton,
+                {
+                  backgroundColor: canSubmit
+                    ? semanticColors.accent
+                    : semanticColors.disabledBg,
+                },
+              ]}
+            >
+              <Text
+                style={[
+                  styles.modalSubmitLabel,
+                  {
+                    color: canSubmit
+                      ? semanticColors.textOnAccent
