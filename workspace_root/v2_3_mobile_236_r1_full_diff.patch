+
+  it('hides RSVP actions once the event is reflected', () => {
+    mockEventHooks.detail = {
+      ...mockEventHooks.detail,
+      data: makeEvent({ state: 'reflected', reflected_at: '2026-07-02T00:00:00.000Z' }),
+    };
+    const { queryByTestId } = render(<CommunityEventDetailScreen />);
