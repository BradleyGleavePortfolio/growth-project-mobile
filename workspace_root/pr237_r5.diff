+      version: 1,
+      planId,
+      batch: {
+        base_revision_index: batch.baseRevisionIndex,
+        lock_token: batch.lockToken,
+        ops: batch.ops,
+        cause: batch.cause,
+      },
+      idempotencyKey: batch.idempotencyKey,
+      queuedAtMs: Date.now(),
+    };
