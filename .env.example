# =============================================================================
# Mobile app env vars (pre-TestFlight, May 2026)
# =============================================================================
# Required vars are hard-checked at module load in src/config/env.ts — a
# release build will throw at startup if any are missing, rather than ship a
# silently broken binary.
#
# Provision per-environment in EAS via:
#   eas env:create --environment <production|preview|development> \
#     --name <KEY> --value <value> [--visibility plaintext|sensitive]
# List with `eas env:list`. Pull to local for testing with `eas env:pull`.
# =============================================================================

# -------- REQUIRED ----------------------------------------------------------

# Backend API base URL. Required in production/preview. Dev can omit (env.ts
# falls back to the Fly.io dev URL when __DEV__ is true).
#   eas env:create --environment production --name EXPO_PUBLIC_API_URL \
#     --value https://api.trygrowthproject.com/api
#   eas env:create --environment preview    --name EXPO_PUBLIC_API_URL \
#     --value https://api.trygrowthproject.com/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Supabase project credentials. Required in ALL builds (dev/preview/prod). The
# anon key is safe to ship with the app, but provisioning per-environment lets
# staging/prod diverge cleanly.
#   eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_URL \
#     --value https://<project>.supabase.co
#   eas env:create --environment production --name EXPO_PUBLIC_SUPABASE_ANON_KEY \
#     --value <anon-key>
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# -------- OPTIONAL ----------------------------------------------------------

# Help center base URL. Defaults to https://app.trygrowthproject.com/help when
# unset. Override per-environment if the help site moves to its own host
# (e.g. https://help.trygrowthproject.com). Trailing slashes are normalised.
# EXPO_PUBLIC_HELP_BASE_URL=https://app.trygrowthproject.com/help

# Mock-data flags. Default OFF in production. When true the related screen
# uses bundled fixtures instead of live API calls — useful for screenshot
# generation, demos, and offline dev. Production builds MUST leave these
# unset or set to "false".
#   eas env:create --environment production --name EXPO_PUBLIC_USE_MOCK_COMMAND_CENTER --value false
#   eas env:create --environment production --name EXPO_PUBLIC_NOTIFICATIONS_MOCK     --value false
# EXPO_PUBLIC_USE_MOCK_COMMAND_CENTER=false
# EXPO_PUBLIC_NOTIFICATIONS_MOCK=false

# PostHog analytics — both vars no-op when unset (the SDK is constructed with
# an empty key). EXPO_PUBLIC_POSTHOG_API_KEY is the canonical name;
# EXPO_PUBLIC_POSTHOG_KEY is accepted as a legacy alias.
# EXPO_PUBLIC_POSTHOG_API_KEY=phc_xxx
# EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry DSN — when unset, initSentry() in src/services/sentry.ts is a no-op
# and Sentry.wrap() returns the component unchanged. Required for any
# TestFlight / Play Internal candidate (production crashes are blind without
# it). The companion EAS-time secret SENTRY_AUTH_TOKEN (NOT an EXPO_PUBLIC_
# var; never bundled) drives the sourcemap upload — see README "Sentry
# release tracking".
# EXPO_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Sentry environment tag. Defaults to "production" when unset, which is fine
# for production EAS profile builds but wrong for preview / internal — leaving
# this unset on a preview build pollutes the prod Sentry board with QA
# crashes. Set per-profile in EAS.
#   eas env:create --environment preview    --name EXPO_PUBLIC_ENVIRONMENT --value preview
#   eas env:create --environment production --name EXPO_PUBLIC_ENVIRONMENT --value production
# EXPO_PUBLIC_ENVIRONMENT=production

# Crisp support inbox website ID. Required for the in-app Support tab
# (Settings → Support). When unset, the overlay opens empty. Find it in
# the Crisp dashboard under Settings → Website Settings → Setup
# instructions. Safe to ship (public site key).
#   eas env:create --environment production --name EXPO_PUBLIC_CRISP_WEBSITE_ID --value <website-id>
# EXPO_PUBLIC_CRISP_WEBSITE_ID=00000000-0000-0000-0000-000000000000

# Stripe publishable key (client-safe). Required to initialise the in-app
# PaymentSheet from PackageSelectionSheet. The backend issues per-session
# ephemeral keys and PaymentIntents; the publishable key only authenticates
# the client SDK against the same Stripe account. Use the TEST key for
# preview/dev, the LIVE key for production.
#   eas env:create --environment production --name EXPO_PUBLIC_STRIPE_PK \
#     --value pk_live_xxx
#   eas env:create --environment preview    --name EXPO_PUBLIC_STRIPE_PK \
#     --value pk_test_xxx
# EXPO_PUBLIC_STRIPE_PK=pk_test_xxx

# Google sign-in is brokered through Supabase, not the native Google SDK.
# The Google OAuth client/secret is configured in the Supabase dashboard under
# Authentication → Providers → Google. There is NO per-platform client ID to
# embed in the mobile build, so no values are needed here. See
# PLAY_STORE_READINESS.md for the redirect URI Google Cloud Console must allow.

# v1-6 coach community surface — default OFF until launch
EXPO_PUBLIC_FF_COACH_COMMUNITY=false

# v2-2 coach ack signals + inbox SLA badges — default OFF until launch
EXPO_PUBLIC_FF_COMMUNITY_ACKS=false

# Community v2-3 — event objects (client RSVP + coach lifecycle). Default OFF.
EXPO_PUBLIC_FF_COMMUNITY_EVENTS=false

# Roman P1 chat surface (client + coach) — default OFF until ops flips it on
# alongside the backend FEATURE_ROMAN_CHAT_ENABLED gate.
EXPO_PUBLIC_FF_ROMAN_CHAT=false

# v3-1 community challenges (opt-in leaderboard) — default OFF until launch
EXPO_PUBLIC_FF_COMMUNITY_CHALLENGES=false
# MWB-4 — workout-builder autosave (Google-Docs-style save). Default OFF.
# When off, the coach workout builder keeps its legacy explicit-Save (PUT
# replace-all) behaviour with zero autosave traffic. Flip on only once the
# backend FEATURE_MWB_AUTOSAVE_UNDO gate is live in the target environment.
EXPO_PUBLIC_FF_MWB_AUTOSAVE=false
