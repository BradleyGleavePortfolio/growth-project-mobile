# Backend API base URL. Required in production builds; dev can omit.
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Supabase project credentials. Required in all builds (dev/preview/prod).
# Anon key is safe to ship with the app, but centralizing here lets us rotate
# without a code change and keeps staging/prod separable.
EXPO_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google OAuth client IDs (optional in dev)
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=your_google_ios_client_id_here
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=your_google_android_client_id_here
