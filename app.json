{
  "expo": {
    "name": "The Growth Project",
    "slug": "tgp-health-and-wellness",
    "scheme": [
      "tgp",
      "com.growthproject.app"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.growthproject.app",
      "buildNumber": "5",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Unlock the app and confirm sensitive actions with Face ID",
        "NSHealthShareUsageDescription": "The Growth Project uses your Apple Health data so your coach can personalize training, recovery, and check-ins around real signals (sleep, heart rate, workouts).",
        "NSHealthUpdateUsageDescription": "The Growth Project may write workouts you log to Apple Health so all your activity stays in one place.",
        "NSMotionUsageDescription": "The Growth Project reads motion and step activity so your coach can track daily movement and progress."
      },
      "associatedDomains": [
        "applinks:app.trygrowthproject.com"
      ],
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#F5EFE4"
      },
      "package": "com.growthproject.app",
      "versionCode": 4,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "tgp",
              "host": "join"
            },
            {
              "scheme": "tgp",
              "host": "invite"
            },
            {
              "scheme": "tgp",
              "host": "reset-password"
            },
            {
              "scheme": "https",
              "host": "app.trygrowthproject.com",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "app.trygrowthproject.com",
              "pathPrefix": "/invite/accept"
            },
            {
              "scheme": "https",
              "host": "app.trygrowthproject.com",
              "pathPrefix": "/reset-password"
            },
            {
              "scheme": "tgp",
              "host": "p"
            },
            {
              "scheme": "https",
              "host": "app.trygrowthproject.com",
              "pathPrefix": "/p"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_SLEEP",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED",
        "android.permission.health.READ_TOTAL_CALORIES_BURNED",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_OXYGEN_SATURATION",
        "android.permission.health.READ_RESPIRATORY_RATE",
        "android.permission.health.READ_HEART_RATE_VARIABILITY",
        "android.permission.health.READ_BODY_TEMPERATURE",
        "android.permission.health.READ_WEIGHT",
        "android.permission.health.READ_BODY_FAT",
        "android.permission.health.READ_VO2_MAX",
        "android.permission.health.READ_BASAL_BODY_TEMPERATURE",
        "android.permission.health.READ_BLOOD_PRESSURE",
        "android.permission.health.READ_HEALTH_DATA_IN_BACKGROUND",
        "android.permission.ACTIVITY_RECOGNITION",
        "com.samsung.android.hardware.sensormanager.permission.READ_ADDITIONAL_HEALTH_DATA"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#F5EFE4"
        }
      ],
      "expo-sqlite",
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-font",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock the app and confirm sensitive actions with Face ID"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2C4A36",
          "defaultChannel": "default"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "the-growth-project",
          "project": "growth-project-mobile",
          "url": "https://sentry.io/"
        }
      ],
      "@sentry/react-native",
      "expo-sharing",
      [
        "react-native-health",
        {
          "healthSharePermission": "The Growth Project uses your Apple Health data so your coach can personalize training, recovery, and check-ins around real signals (sleep, heart rate, workouts).",
          "healthUpdatePermission": "The Growth Project may write workouts you log to Apple Health so all your activity stays in one place."
        }
      ],
      "react-native-health-connect"
    ],
    "extra": {
      "storeListings": {
        "playStoreUrl": null,
        "appStoreUrl": "https://apps.apple.com/us/app/the-growth-project/id6765847915"
      },
      "eas": {
        "projectId": "a12c3345-cc8c-4c2c-9c57-711c10a57c1c"
      }
    },
    "owner": "the-growth-project"
  }
}
