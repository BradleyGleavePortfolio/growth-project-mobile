{
  "expo": {
    "name": "The Growth Project",
    "slug": "tgp-health-and-wellness",
    "scheme": "tgp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.growthproject.app",
      "buildNumber": "2",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for barcode scanning to log food items",
        "ITSAppUsesNonExemptEncryption": false
      },
      "associatedDomains": ["applinks:app.trygrowthproject.com"]
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#F5EFE4"
      },
      "package": "com.growthproject.app",
      "versionCode": 2,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            { "scheme": "tgp", "host": "join" },
            { "scheme": "https", "host": "app.trygrowthproject.com", "pathPrefix": "/join" }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-web-browser",
      "expo-font",
      "expo-localization"
    ],
    "extra": {
      "eas": {
        "projectId": "3aeadee6-34c5-4231-85b9-aff9f7ea3c5a"
      }
    },
    "owner": "bradley1031"
  }
}
