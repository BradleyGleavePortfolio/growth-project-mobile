{
  "expo": {
    "name": "The Growth Project",
    "slug": "tgp-health-and-wellness",
    "scheme": "tgp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF8F3"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.growthproject.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for barcode scanning to log food items",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#FAF8F3"
      },
      "package": "com.growthproject.app",
      "versionCode": 1
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-web-browser",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "3aeadee6-34c5-4231-85b9-aff9f7ea3c5a"
      }
    },
    "owner": "bradley1031"
  }
}
