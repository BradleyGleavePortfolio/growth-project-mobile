{
  "expo": {
    "name": "The Growth Project",
    "slug": "tgp-health-and-wellness",
    "scheme": "tgp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EFE4"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.growthproject.app",
      "buildNumber": "4",
      "infoPlist": {
        "NSCameraUsageDescription": "Used for barcode scanning to log food items",
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "Unlock the app and confirm sensitive actions with Face ID"
      },
      "associatedDomains": [
        "applinks:app.trygrowthproject.com"
      ],
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#F5EFE4"
      },
      "package": "com.growthproject.app",
      "versionCode": 4,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "tgp",
              "host": "join"
            },
            {
              "scheme": "tgp",
              "host": "invite"
            },
            {
              "scheme": "https",
              "host": "app.trygrowthproject.com",
              "pathPrefix": "/join"
            },
            {
              "scheme": "https",
              "host": "app.trygrowthproject.com",
              "pathPrefix": "/invite/accept"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-font",
      "expo-localization",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Unlock the app and confirm sensitive actions with Face ID"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#2C4A36",
          "defaultChannel": "default"
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "the-growth-project",
          "project": "growth-project-mobile",
          "url": "https://sentry.io/"
        }
      ],
      "@sentry/react-native",
      "expo-sharing"
    ],
    "extra": {
      "storeListings": {
        "playStoreUrl": null,
        "appStoreUrl": "https://apps.apple.com/us/app/the-growth-project/id6765847915"
      },
      "eas": {
        "projectId": "a12c3345-cc8c-4c2c-9c57-711c10a57c1c"
      }
    },
    "owner": "the-growth-project"
  }
}
